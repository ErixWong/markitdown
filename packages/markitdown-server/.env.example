# Server
MARKITDOWN_SERVER_HOST=0.0.0.0
MARKITDOWN_SERVER_PORT=8000
MARKITDOWN_STORAGE_DIR=/app/storage

# Auth (set to enable, min 32 chars with letters + digits)
# MARKITDOWN_API_KEY=

# Admin API Token (min 32 chars for security)
# MARKITDOWN_ADMIN_TOKEN=

# OCR (requires LLM Vision API key)
MARKITDOWN_OCR_ENABLED=true
# Required: OpenAI-compatible API key for LLM Vision OCR
MARKITDOWN_OCR_API_KEY=sk-xxxxxxxxx
# Optional: Custom API base URL (for Azure, DeepSeek, etc.)
# MARKITDOWN_OCR_API_BASE=https://api.openai.com/v1
# Optional: Model name (default: gpt-4o)
# MARKITDOWN_OCR_MODEL=gpt-4o

# Limits
MARKITDOWN_MAX_FILE_SIZE=100MB

# CORS (comma-separated origins, or * for all)
MARKITDOWN_CORS_ORIGINS=*

# MCP
MARKITDOWN_MCP_STREAMING=false

# SSE heartbeat interval in seconds
MARKITDOWN_SSE_HEARTBEAT=30

# Task Queue Strategy
MARKITDOWN_DISPATCH_STRATEGY=fifo
MARKITDOWN_MAX_QUEUE_SIZE=100
MARKITDOWN_QUEUE_TIMEOUT=5.0

# Ratio Strategy (only when MARKITDOWN_DISPATCH_STRATEGY=ratio)
MARKITDOWN_SMALL_RATIO=0.4
MARKITDOWN_LARGE_RATIO=0.6
MARKITDOWN_FILE_THRESHOLD_MB=5
