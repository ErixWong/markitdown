# MarkItDown OCR MCP Server Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# OCR Configuration (Required for OCR functionality)
# =============================================================================

# LLM API key for OCR (OpenAI-compatible)
MARKITDOWN_OCR_API_KEY=sk-xxx

# LLM model for OCR (e.g., gpt-4o, gpt-4-vision-preview, gemini-2.0-flash)
MARKITDOWN_OCR_MODEL=gpt-4o

# LLM API base URL (optional, defaults to OpenAI)
# MARKITDOWN_OCR_API_BASE=https://api.openai.com/v1

# =============================================================================
# MCP Server Configuration
# =============================================================================

# Enable OCR by default (optional, default: false)
# MARKITDOWN_OCR_ENABLED=false

# Storage directory for task files (optional, default: ./storage)
# MARKITDOWN_STORAGE_DIR=./storage

# Maximum concurrent processing tasks (optional, default: 3)
# Higher values allow more parallel processing but may trigger API rate limits
# MARKITDOWN_MAX_CONCURRENT=3

# =============================================================================
# Server Mode Configuration (for HTTP mode)
# =============================================================================

# Bearer Token for HTTP authentication (optional, default: disabled)
# Minimum 32 characters, must contain both letters and numbers
# When set, all HTTP endpoints require "Authorization: Bearer <token>" header
# MARKITDOWN_API_KEY=your-secret-token-32-chars-min-with-mixed-123

# MCP Streaming Mode (optional, default: false)
# If true: Uses SSE streams for MCP communication with real-time progress notifications
# If false (default): Uses simple JSON responses, clients poll via get_task tool
# MARKITDOWN_MCP_STREAMING=false

# Host to bind to (optional, default: 127.0.0.1)
# MARKITDOWN_MCP_HOST=127.0.0.1

# Port to listen on (optional, default: 3001)
# MARKITDOWN_MCP_PORT=3001

# =============================================================================
# File Upload Configuration
# =============================================================================

# Maximum file size for upload in MB (optional, default: 100)
# This limit applies when using file_path parameter to submit files
# Note: MCP protocol has a hard limit of 4MB for Base64 encoded content
# MARKITDOWN_MAX_FILE_SIZE_MB=100